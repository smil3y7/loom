# Loom UI — Environment Configuration
# Kopiraj v .env.local za lokalni razvoj (gitignored)
# Za produkcijo nastavi v Vercel dashboard

# API URL
# Lokalno: http://localhost:8000
# Produkcija: https://tvoj-loom-api.vercel.app
VITE_API_URL=http://localhost:8000

# App URL (za CORS in links)
# Lokalno: http://localhost:5173
# Produkcija: https://loom-sentria.vercel.app
VITE_APP_URL=http://localhost:5173
