{
  "version": 2,
  "name": "loom",

  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/health",
      "dest": "api/index.py"
    }
  ],

  "env": {
    "PYTHONPATH": "."
  },

  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 512
    }
  }
}
